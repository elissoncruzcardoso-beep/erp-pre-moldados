generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ItemType {
  MATERIA_PRIMA
  INSUMO
  PRODUTO_ACABADO
  PECA_PRE_MOLDADA
  FORMA_MOLDE
  SERVICO
}

enum FinancialGroupType {
  ENTRADA
  SAIDA
}

enum ProductionOrderStatus {
  RASCUNHO
  PLANEJADA
  LIBERADA
  EM_PRODUCAO
  PAUSADA
  AGUARDANDO_QUALIDADE
  ENCERRADA
  CANCELADA
}

enum ProductionStageStatus {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDA
  BLOQUEADA
}

enum StockMovementType {
  ENTRADA_COMPRA
  SAIDA_PRODUCAO
  ENTRADA_PRODUCAO
  TRANSFERENCIA
  AJUSTE_POSITIVO
  AJUSTE_NEGATIVO
  RESERVA
  ESTORNO
}

enum LotStatus {
  LIBERADO
  BLOQUEADO
  EM_ANALISE
  VENCIDO
  CONSUMIDO
}

enum PurchaseRequestStatus {
  ABERTA
  EM_COTACAO
  APROVADA
  REPROVADA
  CONVERTIDA_PEDIDO
  CANCELADA
}

enum PurchaseQuoteStatus {
  RECEBIDA
  APROVADA
  REPROVADA
  CANCELADA
}

enum PurchaseOrderStatus {
  EMITIDO
  ENVIADO
  PARCIALMENTE_RECEBIDO
  RECEBIDO
  CANCELADO
}

enum PurchaseReceiptStatus {
  LIBERADO_ESTOQUE
  DIVERGENTE
  CANCELADO
}

enum AccountPayableStatus {
  ABERTO
  PROGRAMADO
  PAGO
  CANCELADO
}

enum AccountReceivableStatus {
  ABERTO
  FATURADO
  RECEBIDO
  CANCELADO
}

enum DirectSaleStatus {
  ATIVA
  CANCELADA
}

enum ProductionBatchStatus {
  EM_CURA
  APTA_RETIRADA
  RETIRADA_PARCIAL
  RETIRADA_TOTAL
  BLOQUEADA
}

enum AuditAction {
  LOGIN
  CREATE
  UPDATE
  DELETE
  APPROVE
  CANCEL
  STOCK_MOVE
  STOCK_REVERSAL
  PRODUCTION_START
  PRODUCTION_CLOSE
  PERMISSION_CHANGE
}

model User {
  id              String           @id @default(cuid())
  name            String
  email           String           @unique
  passwordHash    String?
  status          UserStatus       @default(ACTIVE)
  department      String?
  roleId          String
  role            Role             @relation(fields: [roleId], references: [id])
  auditLogs       AuditLog[]
  stockMovements  StockMovement[]
  directSales      DirectSale[]
  cancelledDirectSales DirectSale[] @relation("DirectSaleCancelledBy")
  productionNotes ProductionNote[]
  productionDailyLogs ProductionDailyLog[]
  releasedProductionBatches ProductionBatch[] @relation("ProductionBatchReleasedBy")
  purchaseRequests PurchaseRequest[]
  purchaseQuotes  PurchaseQuote[]
  purchaseOrders  PurchaseOrder[]
  purchaseReceipts PurchaseReceipt[]
  accountsPayable AccountPayable[]
  accountPayments AccountPayment[]
  accountsReceivable AccountReceivable[]
  accountReceipts AccountReceipt[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  module      String
  description String
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Company {
  id        String   @id @default(cuid())
  legalName String
  tradeName String?
  document  String?  @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id        String            @id @default(cuid())
  code      String            @unique
  name      String
  document  String?
  email     String?
  phone     String?
  address   String?
  city      String?
  state     String?
  active    Boolean           @default(true)
  orders    ProductionOrder[]
  accountsReceivable AccountReceivable[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model PaymentMethod {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  type      String   @default("A_VISTA")
  active    Boolean  @default(true)
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FinancialSettlementType {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  direction String   @default("ENTRADA")
  active    Boolean  @default(true)
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Supplier {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  document  String?
  email     String?
  phone     String?
  active    Boolean  @default(true)
  lots      Lot[]
  quotes    PurchaseQuote[]
  quoteItems PurchaseQuoteItem[]
  orders    PurchaseOrder[]
  accountsPayable AccountPayable[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UnitOfMeasure {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  decimals  Int      @default(2)
  items     Item[]
  createdAt DateTime @default(now())
}

model InputGroup {
  id                    String             @id @default(cuid())
  code                  String             @unique
  name                  String             @unique
  type                  ItemType           @default(INSUMO)
  defaultFinancialGroupId String?
  defaultFinancialGroup FinancialGroup?    @relation(fields: [defaultFinancialGroupId], references: [id])
  controlsStock         Boolean            @default(true)
  active                Boolean            @default(true)
  note                  String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
}

model FinancialGroup {
  id          String             @id @default(cuid())
  code        String             @unique
  name        String
  type        FinancialGroupType
  category    String?
  costCenter  String?
  active      Boolean            @default(true)
  note        String?
  inputGroups InputGroup[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model Item {
  id                    String            @id @default(cuid())
  code                  String            @unique
  description           String
  type                  ItemType
  group                 String?
  unitId                String
  unit                  UnitOfMeasure     @relation(fields: [unitId], references: [id])
  controlsStock         Boolean           @default(true)
  controlsLot           Boolean           @default(false)
  minimumStock          Decimal           @default(0) @db.Decimal(14, 3)
  standardCost          Decimal           @default(0) @db.Decimal(14, 4)
  curingHours           Int               @default(24)
  active                Boolean           @default(true)
  lots                  Lot[]
  stockBalances         StockBalance[]
  stockMovements        StockMovement[]
  purchaseRequestItems  PurchaseRequestItem[]
  purchaseQuoteItems    PurchaseQuoteItem[]
  purchaseOrderItems    PurchaseOrderItem[]
  compositionsAsProduct Composition[]     @relation("CompositionProduct")
  compositionItems      CompositionItem[]
  productionOrders      ProductionOrder[]
  productionDailyLogItems ProductionDailyLogItem[]
  productionBatches     ProductionBatch[]
  directSales            DirectSale[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
}

model Warehouse {
  id             String          @id @default(cuid())
  code           String          @unique
  name           String
  type           String?
  allowsNegative Boolean         @default(false)
  active         Boolean         @default(true)
  balances       StockBalance[]
  originMoves    StockMovement[] @relation("OriginWarehouse")
  targetMoves    StockMovement[] @relation("TargetWarehouse")
  purchaseReceipts PurchaseReceipt[]
  directSales    DirectSale[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Lot {
  id             String          @id @default(cuid())
  code           String          @unique
  itemId         String
  item           Item            @relation(fields: [itemId], references: [id])
  supplierId     String?
  supplier       Supplier?       @relation(fields: [supplierId], references: [id])
  supplierLot    String?
  manufacturedAt DateTime?
  expiresAt      DateTime?
  status         LotStatus       @default(EM_ANALISE)
  balances       StockBalance[]
  movements      StockMovement[]
  purchaseReceipts PurchaseReceipt[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model StockBalance {
  id          String    @id @default(cuid())
  itemId      String
  item        Item      @relation(fields: [itemId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  lotId       String?
  lot         Lot?      @relation(fields: [lotId], references: [id])
  quantity    Decimal   @default(0) @db.Decimal(14, 3)
  reserved    Decimal   @default(0) @db.Decimal(14, 3)
  updatedAt   DateTime  @updatedAt

  @@unique([itemId, warehouseId, lotId])
}

model StockMovement {
  id                String             @id @default(cuid())
  type              StockMovementType
  itemId            String
  item              Item               @relation(fields: [itemId], references: [id])
  quantity          Decimal            @db.Decimal(14, 3)
  unitCost          Decimal            @default(0) @db.Decimal(14, 4)
  totalCost         Decimal            @default(0) @db.Decimal(14, 4)
  originWarehouseId String?
  originWarehouse   Warehouse?         @relation("OriginWarehouse", fields: [originWarehouseId], references: [id])
  targetWarehouseId String?
  targetWarehouse   Warehouse?         @relation("TargetWarehouse", fields: [targetWarehouseId], references: [id])
  lotId             String?
  lot               Lot?               @relation(fields: [lotId], references: [id])
  productionOrderId String?
  productionOrder   ProductionOrder?   @relation(fields: [productionOrderId], references: [id])
  purchaseReceipt   PurchaseReceipt?
  directSale         DirectSale?
  userId            String
  user              User               @relation(fields: [userId], references: [id])
  document          String?
  justification     String?
  createdAt         DateTime           @default(now())
}

model DirectSale {
  id               String           @id @default(cuid())
  number           String           @unique
  customerName     String
  customerDocument String?
  itemId           String
  item             Item             @relation(fields: [itemId], references: [id])
  warehouseId      String
  warehouse        Warehouse        @relation(fields: [warehouseId], references: [id])
  stockMovementId  String?          @unique
  stockMovement    StockMovement?   @relation(fields: [stockMovementId], references: [id])
  createdById      String
  createdBy        User             @relation(fields: [createdById], references: [id])
  cancelledById    String?
  cancelledBy      User?            @relation("DirectSaleCancelledBy", fields: [cancelledById], references: [id])
  status           DirectSaleStatus @default(ATIVA)
  quantity         Decimal          @db.Decimal(14, 3)
  unitPrice        Decimal          @default(0) @db.Decimal(14, 4)
  grossTotal       Decimal          @default(0) @db.Decimal(14, 4)
  discount         Decimal          @default(0) @db.Decimal(14, 4)
  finalTotal       Decimal          @default(0) @db.Decimal(14, 4)
  paymentMethod    String?
  note             String?
  consumedLots     Json?
  issuedAt         DateTime         @default(now())
  cancelledAt      DateTime?
  cancelReason     String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model PurchaseRequest {
  id             String                @id @default(cuid())
  number         String                @unique
  requesterId    String
  requester      User                  @relation(fields: [requesterId], references: [id])
  department     String?
  costCenter     String?
  priority       String                @default("NORMAL")
  neededAt       DateTime?
  status         PurchaseRequestStatus @default(ABERTA)
  justification  String?
  items          PurchaseRequestItem[]
  quotes         PurchaseQuote[]
  orders         PurchaseOrder[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
}

model PurchaseRequestItem {
  id                String          @id @default(cuid())
  purchaseRequestId String
  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  itemId            String
  item              Item            @relation(fields: [itemId], references: [id])
  quantity          Decimal         @db.Decimal(14, 3)
  note              String?
  quoteItems        PurchaseQuoteItem[]
}

model PurchaseQuote {
  id                String              @id @default(cuid())
  number            String              @unique
  purchaseRequestId String
  purchaseRequest   PurchaseRequest     @relation(fields: [purchaseRequestId], references: [id])
  supplierId        String
  supplier          Supplier            @relation(fields: [supplierId], references: [id])
  createdById       String
  createdBy         User                @relation(fields: [createdById], references: [id])
  status            PurchaseQuoteStatus @default(RECEBIDA)
  deliveryDays      Int?
  paymentTerms      String?
  validUntil        DateTime?
  freightCost       Decimal             @default(0) @db.Decimal(14, 4)
  totalValue        Decimal             @db.Decimal(14, 4)
  note              String?
  items             PurchaseQuoteItem[]
  purchaseOrder     PurchaseOrder?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

model PurchaseQuoteItem {
  id                    String              @id @default(cuid())
  purchaseQuoteId       String
  purchaseQuote         PurchaseQuote       @relation(fields: [purchaseQuoteId], references: [id], onDelete: Cascade)
  purchaseRequestItemId String
  purchaseRequestItem   PurchaseRequestItem @relation(fields: [purchaseRequestItemId], references: [id])
  itemId                String
  item                  Item                @relation(fields: [itemId], references: [id])
  supplierId            String
  supplier              Supplier            @relation(fields: [supplierId], references: [id])
  quantity              Decimal             @db.Decimal(14, 3)
  unitPrice             Decimal             @default(0) @db.Decimal(14, 4)
  discountValue         Decimal             @default(0) @db.Decimal(14, 4)
  freightCost           Decimal             @default(0) @db.Decimal(14, 4)
  totalValue            Decimal             @default(0) @db.Decimal(14, 4)
  note                  String?

  @@unique([purchaseQuoteId, purchaseRequestItemId])
}

model PurchaseOrder {
  id                String              @id @default(cuid())
  number            String              @unique
  purchaseQuoteId   String              @unique
  purchaseQuote     PurchaseQuote       @relation(fields: [purchaseQuoteId], references: [id])
  purchaseRequestId String
  purchaseRequest   PurchaseRequest     @relation(fields: [purchaseRequestId], references: [id])
  supplierId        String
  supplier          Supplier            @relation(fields: [supplierId], references: [id])
  createdById       String
  createdBy         User                @relation(fields: [createdById], references: [id])
  status            PurchaseOrderStatus @default(EMITIDO)
  issuedAt          DateTime            @default(now())
  expectedDeliveryAt DateTime?
  paymentTerms      String?
  freightCost       Decimal             @default(0) @db.Decimal(14, 4)
  totalValue        Decimal             @db.Decimal(14, 4)
  note              String?
  items             PurchaseOrderItem[]
  receipts          PurchaseReceipt[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  itemId          String
  item            Item          @relation(fields: [itemId], references: [id])
  quantity        Decimal       @db.Decimal(14, 3)
  unitPrice       Decimal       @default(0) @db.Decimal(14, 4)
  totalValue      Decimal       @default(0) @db.Decimal(14, 4)
  note            String?
  receipts        PurchaseReceipt[]
}

model PurchaseReceipt {
  id                  String                @id @default(cuid())
  number              String                @unique
  purchaseOrderId     String
  purchaseOrder       PurchaseOrder         @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderItemId String
  purchaseOrderItem   PurchaseOrderItem     @relation(fields: [purchaseOrderItemId], references: [id])
  warehouseId         String
  warehouse           Warehouse             @relation(fields: [warehouseId], references: [id])
  lotId               String?
  lot                 Lot?                  @relation(fields: [lotId], references: [id])
  stockMovementId     String?               @unique
  stockMovement       StockMovement?        @relation(fields: [stockMovementId], references: [id])
  accountPayable      AccountPayable?
  receivedById        String
  receivedBy          User                  @relation(fields: [receivedById], references: [id])
  status              PurchaseReceiptStatus @default(LIBERADO_ESTOQUE)
  invoiceNumber       String?
  supplierLot         String?
  receivedQuantity    Decimal               @db.Decimal(14, 3)
  acceptedQuantity    Decimal               @db.Decimal(14, 3)
  rejectedQuantity    Decimal               @default(0) @db.Decimal(14, 3)
  unitCost            Decimal               @default(0) @db.Decimal(14, 4)
  totalCost           Decimal               @default(0) @db.Decimal(14, 4)
  receivedAt          DateTime              @default(now())
  note                String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
}

model AccountPayable {
  id                String               @id @default(cuid())
  number            String               @unique
  purchaseReceiptId String               @unique
  purchaseReceipt   PurchaseReceipt      @relation(fields: [purchaseReceiptId], references: [id])
  supplierId        String
  supplier          Supplier             @relation(fields: [supplierId], references: [id])
  createdById       String
  createdBy         User                 @relation(fields: [createdById], references: [id])
  status            AccountPayableStatus @default(ABERTO)
  description       String
  documentNumber    String?
  costCenter        String?
  issueDate         DateTime             @default(now())
  dueDate           DateTime
  amount            Decimal              @db.Decimal(14, 4)
  paidAmount        Decimal              @default(0) @db.Decimal(14, 4)
  paidAt            DateTime?
  note              String?
  payments          AccountPayment[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

model AccountPayment {
  id               String         @id @default(cuid())
  accountPayableId String
  accountPayable   AccountPayable @relation(fields: [accountPayableId], references: [id], onDelete: Cascade)
  paidById         String
  paidBy           User           @relation(fields: [paidById], references: [id])
  paymentDate      DateTime       @default(now())
  amount           Decimal        @db.Decimal(14, 4)
  method           String
  reference        String?
  note             String?
  createdAt        DateTime       @default(now())
}

model AccountReceivable {
  id             String                  @id @default(cuid())
  number         String                  @unique
  customerId     String
  customer       Customer                @relation(fields: [customerId], references: [id])
  createdById    String
  createdBy      User                    @relation(fields: [createdById], references: [id])
  status         AccountReceivableStatus @default(ABERTO)
  description    String
  documentNumber String?
  costCenter     String?
  issueDate      DateTime                @default(now())
  dueDate        DateTime
  amount         Decimal                 @db.Decimal(14, 4)
  receivedAmount Decimal                 @default(0) @db.Decimal(14, 4)
  receivedAt     DateTime?
  note           String?
  receipts       AccountReceipt[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
}

model AccountReceipt {
  id                  String            @id @default(cuid())
  accountReceivableId String
  accountReceivable   AccountReceivable @relation(fields: [accountReceivableId], references: [id], onDelete: Cascade)
  receivedById        String
  receivedBy          User              @relation(fields: [receivedById], references: [id])
  receiptDate         DateTime          @default(now())
  amount              Decimal           @db.Decimal(14, 4)
  method              String
  reference           String?
  note                String?
  createdAt           DateTime          @default(now())
}

model Mold {
  id        String            @id @default(cuid())
  code      String            @unique
  name      String
  capacity  Decimal?          @db.Decimal(14, 3)
  active    Boolean           @default(true)
  orders    ProductionOrder[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model Composition {
  id           String            @id @default(cuid())
  code         String            @unique
  productId    String
  product      Item              @relation("CompositionProduct", fields: [productId], references: [id])
  version      String
  revision     String
  baseQuantity Decimal           @default(1) @db.Decimal(14, 3)
  expectedLoss Decimal           @default(0) @db.Decimal(6, 3)
  curingHours  Int?
  approved     Boolean           @default(false)
  items        CompositionItem[]
  orders       ProductionOrder[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model CompositionItem {
  id            String      @id @default(cuid())
  compositionId String
  composition   Composition @relation(fields: [compositionId], references: [id], onDelete: Cascade)
  itemId        String
  item          Item        @relation(fields: [itemId], references: [id])
  quantity      Decimal     @db.Decimal(14, 3)
  lossPercent   Decimal     @default(0) @db.Decimal(6, 3)
  stage         String?
}

model ProductionOrder {
  id               String                @id @default(cuid())
  number           String                @unique
  productId        String
  product          Item                  @relation(fields: [productId], references: [id])
  compositionId    String?
  composition      Composition?          @relation(fields: [compositionId], references: [id])
  moldId           String?
  mold             Mold?                 @relation(fields: [moldId], references: [id])
  customerId       String?
  customer         Customer?             @relation(fields: [customerId], references: [id])
  plannedQuantity  Decimal               @db.Decimal(14, 3)
  producedQuantity Decimal               @default(0) @db.Decimal(14, 3)
  expectedDate     DateTime?
  status           ProductionOrderStatus @default(RASCUNHO)
  stages           ProductionStage[]
  notes            ProductionNote[]
  stockMovements   StockMovement[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
}

model ProductionStage {
  id                String                @id @default(cuid())
  productionOrderId String
  productionOrder   ProductionOrder       @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  name              String
  sequence          Int
  status            ProductionStageStatus @default(PENDENTE)
  startedAt         DateTime?
  finishedAt        DateTime?
}

model ProductionNote {
  id                String          @id @default(cuid())
  productionOrderId String
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  userId            String
  user              User            @relation(fields: [userId], references: [id])
  stage             String
  producedQuantity  Decimal         @default(0) @db.Decimal(14, 3)
  lossQuantity      Decimal         @default(0) @db.Decimal(14, 3)
  scrapQuantity     Decimal         @default(0) @db.Decimal(14, 3)
  downtimeMinutes   Int             @default(0)
  note              String?
  createdAt         DateTime        @default(now())
}

model ProductionDailyLog {
  id             String                   @id @default(cuid())
  logDate        DateTime
  teamPresent    String
  weatherMorning String
  weatherAfternoon String
  observation    String?
  createdById    String
  createdBy      User                     @relation(fields: [createdById], references: [id])
  items          ProductionDailyLogItem[]
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@unique([logDate, createdById])
}

model ProductionDailyLogItem {
  id                 String             @id @default(cuid())
  dailyLogId         String
  dailyLog           ProductionDailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  itemId             String
  item               Item               @relation(fields: [itemId], references: [id])
  quantity           Decimal            @db.Decimal(14, 3)
  note               String?
  batch              ProductionBatch?
}

model ProductionBatch {
  id                 String                @id @default(cuid())
  code               String                @unique
  dailyLogItemId     String                @unique
  dailyLogItem       ProductionDailyLogItem @relation(fields: [dailyLogItemId], references: [id], onDelete: Cascade)
  itemId             String
  item               Item                  @relation(fields: [itemId], references: [id])
  producedQuantity   Decimal               @db.Decimal(14, 3)
  curingQuantity     Decimal               @db.Decimal(14, 3)
  releasedQuantity   Decimal               @default(0) @db.Decimal(14, 3)
  status             ProductionBatchStatus @default(EM_CURA)
  producedAt         DateTime
  readyAt            DateTime?
  autoStockedAt      DateTime?
  releasedAt         DateTime?
  releasedById       String?
  releasedBy         User?                 @relation("ProductionBatchReleasedBy", fields: [releasedById], references: [id])
  releaseResponsible String?
  releaseNote        String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
}

model AuditLog {
  id            String      @id @default(cuid())
  userId        String?
  user          User?       @relation(fields: [userId], references: [id])
  module        String
  action        AuditAction
  entity        String
  entityId      String?
  previousValue Json?
  newValue      Json?
  justification String?
  createdAt     DateTime    @default(now())
}
