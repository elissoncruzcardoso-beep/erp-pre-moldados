{
  "name": "erp-pre-moldados-prototype",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "prebuild": "npm run security:check-env && npm run security:check-sql && npm run security:check-queries && npm run security:check-public-exposure && npm run security:check-supabase-rls && npm run security:check-api-errors && npm run security:check-api-auth && npm run security:check-api-audit && npm run security:check-api-observability && npm run security:check-health && npm run security:check-migrations && prisma generate",
    "build": "next build",
    "test": "tsx --test --test-isolation=none tests/*.test.ts",
    "security:check-env": "node scripts/check-env-security.mjs",
    "security:check-sql": "node scripts/check-no-raw-sql.mjs",
    "security:check-queries": "node scripts/check-findmany-limits.mjs",
    "security:check-public-exposure": "node scripts/check-public-exposure.mjs",
    "security:check-supabase-rls": "node scripts/check-supabase-rls-hardening.mjs",
    "security:audit-supabase-live": "node scripts/check-supabase-live-rls.mjs",
    "security:check-api-errors": "node scripts/check-api-error-leaks.mjs",
    "security:check-api-auth": "node scripts/check-api-auth-guards.mjs",
    "security:check-api-audit": "node scripts/check-api-audit-coverage.mjs",
    "security:check-api-observability": "node scripts/check-api-observability.mjs",
    "security:check-health": "node scripts/check-health-route.mjs",
    "security:check-migrations": "node scripts/check-prisma-migrations.mjs",
    "security:readiness": "node scripts/security-readiness-report.mjs",
    "monitoring:check-health": "node scripts/monitoring/check-health-url.mjs",
    "monitoring:check-health-evidence": "node scripts/monitoring/check-health-url.mjs --check-evidence",
    "monitoring:install-windows-health": "powershell -ExecutionPolicy Bypass -File scripts/monitoring/install-windows-health-monitor.ps1",
    "backup:check-config": "node scripts/backup/check-backup-config.mjs",
    "backup:check-s3": "node scripts/backup/check-s3-backup-posture.mjs",
    "backup:check-s3-evidence": "node scripts/backup/check-s3-backup-posture.mjs --check-evidence",
    "backup:check-evidence": "node scripts/backup/check-backup-evidence.mjs",
    "backup:check-restore-drill": "node scripts/backup/check-restore-drill-evidence.mjs",
    "backup:readiness": "node scripts/backup/backup-readiness-report.mjs",
    "backup:init-env": "powershell -ExecutionPolicy Bypass -File scripts/backup/init-backup-env.ps1",
    "backup:install-windows-tasks": "powershell -ExecutionPolicy Bypass -File scripts/backup/install-windows-backup-tasks.ps1",
    "backup:full": "powershell -ExecutionPolicy Bypass -File scripts/backup/backup-full-postgres.ps1",
    "backup:incremental": "node scripts/backup/export-incremental.mjs",
    "backup:restore-drill": "powershell -ExecutionPolicy Bypass -File scripts/backup/restore-drill.ps1",
    "maintenance:audit-retention": "tsx scripts/maintenance/cleanup-audit-logs.ts",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "user:set-admin-password": "tsx prisma/set-admin-password.ts",
    "telegram:set-webhook": "node scripts/telegram-set-webhook.mjs"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^6.19.3",
    "dotenv": "^16.6.1",
    "lucide-react": "^0.468.0",
    "next": "^16.1.5",
    "pg": "^8.21.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.1.5",
    "prisma": "^6.19.3",
    "tsx": "^4.22.2",
    "typescript": "^5.7.2"
  }
}
