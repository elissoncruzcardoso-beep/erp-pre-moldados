    "pg": "^8.21.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.1.5",
    "prisma": "^6.19.3",
    "tsx": "^4.22.2",
    "typescript": "^5.7.2"
